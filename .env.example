# DiffWhisperer: Configuration Template
# Copy this file to .env and fill in your actual API Key.
# DO NOT COMMIT YOUR ACTUAL .ENV FILE!

# Google GenAI API Key (Get it from https://aistudio.google.com/)
GEMMA_API_KEY=your_google_api_key_here

# Optional: Model selection (Defaulting to Gemma 4 31B)
# GEMMA_MODEL_31B=models/gemma-4-31b-it
# GEMMA_MODEL_26B=models/gemma-4-26b-a4b-it
